# Legacy private app token for MVP usage.
#
# Before running preflight, a HubSpot super admin must create a legacy private app:
# 1. HubSpot > Development > Legacy apps.
# 2. Create legacy app > Private.
# 3. Add the V1 CRM/Sales core scopes listed in docs/legacy_private_app_setup.md.
# 4. Auth > Show token > Copy.
# 5. Paste the token below.
#
# Never commit this file after adding a real token.
HUBSPOT_PRIVATE_APP_TOKEN=pat-na1-REPLACE_ME

# Optional overrides.
HUBSPOT_BASE_URL=https://api.hubapi.com
HUBSPOT_API_VERSION=2026-03
CRM_AGENT_OUTDIR=.
